# ──────────────────────────────────────────
# CONFIGURACIÓN LOCAL (Docker)
# Copia este archivo a .env y ajusta los valores
# ──────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-cambia-esto-en-produccion
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# Base de datos (Docker local)
DB_NAME=black_line_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4200

# JWT (opcional, valores por defecto en settings)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (consola en desarrollo)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=BlackLine <noreply@blackline.mx>

# URL del frontend (para links en correos)
FRONTEND_URL=http://localhost:4200

# Cloudinary — imágenes en producción (opcional en local)
# Crear cuenta gratis en cloudinary.com → Dashboard → API Keys
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ──────────────────────────────────────────
# PRODUCCIÓN (Render) — NO poner en .env local
# Configurar como variables de entorno en el dashboard de Render
# ──────────────────────────────────────────
# DJANGO_SETTINGS_MODULE=config.settings.production
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# ALLOWED_HOSTS=blackline-backend.onrender.com
# CORS_ALLOWED_ORIGINS=https://blackline.pages.dev
# FRONTEND_URL=https://blackline.pages.dev
# SECRET_KEY=<generado por Render>
# DEBUG=False
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=tu-api-key
# CLOUDINARY_API_SECRET=tu-api-secret
