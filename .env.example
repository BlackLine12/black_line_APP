# ─────────────────────────────────────────────────────────────────────────────
# ENTORNO LOCAL — Docker Compose
# cp .env.example .env  y levanta con: docker-compose up
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=django-insecure-local-dev-only-change-in-prod
DJANGO_SETTINGS_MODULE=config.settings.local
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend,0.0.0.0

# Base de datos (servicio "db" dentro de Docker Compose)
DB_NAME=black_line_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_HOST=db
DB_PORT=5432

# CORS — origen del frontend local
CORS_ALLOWED_ORIGINS=http://localhost:4200

# JWT (opcionales — estos son los defaults)
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email — en local imprime en consola, no envía nada
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=BlackLine <noreply@blackline.mx>

# URL del frontend (para links en correos de notificación)
FRONTEND_URL=http://localhost:4200

# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY — solo necesario si quieres probar uploads en local
# En producción se configura en el Dashboard de Render (no en este archivo)
# Crear cuenta gratis en cloudinary.com → Dashboard → API Keys
# ─────────────────────────────────────────────────────────────────────────────
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
