flowchart LR
    subgraph BACKEND["🐍 Backend (Django REST)"]
        direction TB
        M["models.py\n(ORM fields)"]
        S["serializers.py\n(fields, validation)"]
        V["views.py\n(endpoints, permisos)"]
        SCH["backend/schema.yml\n(OpenAPI 3.0)"]
        M --> S --> V
        V --> SCH
    end

    subgraph CMD["⚙️ Comandos de Sincronización"]
        direction TB
        C1["python manage.py spectacular\n--file schema.yml"]
        C2["npx openapi-typescript\nbackend/schema.yml\n-o frontend/src/app/core/api/types.ts"]
        C1 --> C2
    end

    subgraph FRONTEND["🅰️ Frontend (Angular 19)"]
        direction TB
        T["core/api/types.ts\n(TypeScript types)"]
        SVC["services/*.service.ts\n(HttpClient tipado)"]
        COMP["components/*.ts\n(UI, validación)"]
        T --> SVC --> COMP
    end

    SCH --> C1
    C2 --> T

    subgraph CHECK["🔍 Detección de Drift"]
        DIFF["git diff schema.yml\nantes del PR"]
    end

    SCH -.->|verificar antes PR| CHECK

